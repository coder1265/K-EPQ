<!DOCTYPE html>
<html>

<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-08P5BXDT1F"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() {
            dataLayer.push(arguments);
        }
        gtag("js", new Date());

        gtag("config", "G-08P5BXDT1F");
    </script>
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% seo %}
    <link rel="icon" href="Images/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="Images/favicon-32x32.png" type="image/png" />
    <link rel="icon" type="image/png" href="Images/android-chrome-512x512.png" />
    <link href="CSS/main.css" rel="stylesheet" type="text/css" />
    <script src="js/main.js"></script>
    <!-- Web Awesome CSS theme -->
    <link rel="stylesheet" href="https://early.webawesome.com/webawesome@3.0.0-beta.6/dist/styles/themes/default.css">
    <!-- Web Awesome JS loader (loads all components) -->
    <script type="module" src="https://early.webawesome.com/webawesome@3.0.0-beta.6/dist/webawesome.loader.js"></script>

    {% if page.custom_css %}
    {% for file in page.custom_css %}
    <link rel="stylesheet" href="{{ file }}">
    {% endfor %}
    {% endif %}

    {% if page.custom_js %}
    {% for file in page.custom_js %}
    <script src="{{ file }}"></script>
    {% endfor %}
    {% endif %}

</head>

<body>

    {% include header.html %}
    {% include cookie_part.html %}
    <main>
        {{ content }}
    </main>

    {% include footer.html %}

</body>

</html>